# Example Environment Variables
# Copy this to .env and replace the values with your actual secrets
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
FERNET_KEY=your_fernet_key_here

# Gemini API Key (Get from aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Safe Browsing API Key (Get from Google Cloud Console -> Safe Browsing API)
GOOGLE_SAFE_BROWSING_API_KEY=your_google_safe_browsing_api_key_here

# Email configuration (Gmail SMTP)
GMAIL_USER=your_gmail_username_here@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

DATABASE_URL=sqlite:///neovault.db
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Chrome Extension security configuration (optional)
# Set to your specific Chrome Extension ID to restrict CORS in production
# ALLOWED_EXTENSION_ID=abcdefghijklmnopqrstuvwxyzabcdef

